;
; TUTIL.MAC - Test utility functions for ATTN/11
;
; Console I/O and utility routines
;

; ============================================================
; PUTS - Print null-terminated string
;
; Input:  R0 = pointer to string
; Clobbers: R0, R1
; ============================================================
        .GLOBL  PUTS

PUTS:   MOV     R1, -(SP)       ; save R1
1$:     MOV     (R0)+, R1      ; R1 = char
        BEQ     3$              ; null terminator, done
        MOV     R1, R0
        JSR     PC, PUTC        ; print character
        BR      1$
3$:     MOV     (SP)+, R1       ; restore R1
        RTS     PC

; ============================================================
; PUTC - Print character to console
;
; Input:  R0 = character to print
; Clobbers: R0
; ============================================================
        .GLOBL  PUTC

PUTC:   MOV     R0, R1
        MOV     #1, R0
        EMT     6                ; EMT 6: console output
        MOV     R1, R0
        RTS     PC

; ============================================================
; NEWLN - Print newline
;
; Clobbers: R0
; ============================================================
        .GLOBL  NEWLN

NEWLN:  MOV     #12, R0          ; newline character
        JSR     PC, PUTC
        MOV     #15, R0          ; carriage return
        JSR     PC, PUTC
        RTS     PC

; ============================================================
; PUTSPC - Print space
;
; Clobbers: R0
; ============================================================
        .GLOBL  PUTSPC

PUTSPC:  MOV     #' ', R0         ; space character
        ; fall through to PUTC

; ============================================================
; PUTDEC - Print unsigned decimal integer
;
; Input: R0 = value to print
; Clobbers: R0-R3
; ============================================================
        .GLOBL  PUTDEC

PUTDEC: MOV     R1, -(SP)       ; save R1
        MOV     R0, -(SP)       ; push value
        MOV     #1, R2          ; push count marker (negative = end)
        MOV     R2, -(SP)
        ; Process value
        TST     (SP)+           ; pop and test value
        BEQ     9$
        CLR     R2              ; digit count
        ; Extract digits (in reverse order)
8$:     CLR     R1
        DIV     #10., R0        ; R0=quot, R1=rem
        MOV     R1, -(SP)       ; push digit
        INC     R2
        TST     R0
        BNE     8$
        ; Print digits
        MOV     R2, R1          ; R1 = count
10$:    MOV     (SP)+, R0      ; pop digit
        ADD     #'0', R0
        JSR     PC, PUTC
        DEC     R1
        BNE     10$
        MOV     (SP)+, R1       ; pop count marker
        BR      PUTDN.ED
9$:     MOV     #'0', R0
        JSR     PC, PUTC
PUTDN.ED:
        MOV     (SP)+, R1       ; restore R1
        RTS     PC

; ============================================================
; RAND - Pseudo-random number generator
;
; Returns R0 = 15-bit random value
; Uses a simple linear congruential generator
; Clobbers: R0, R1
; ============================================================
        .GLOBL  RAND

RAND:   MOV     SEED, R0
        MOV     #11035., R1     ; multiplier (LCG parameter)
        MUL     R1, R0          ; R0:R1 = SEED * 11035
        ADD     #12345., R1      ; add increment (LCG parameter)
        MOV     R1, SEED         ; save new seed
        MOV     R1, R0          ; return low 15 bits
        BIC     #100000, R0     ; clear sign bit (15-bit result)
        RTS     PC

; Random seed (initialized to a non-zero value)
SEED:   .WORD   1

; end of TUTIL.MAC
